---
const { headerMode = 'light' } = Astro.props;

const navItems = [
  { label: 'Inicio',      href: '#inicio'      },
  { label: 'Experiencia', href: '#experiencia' },
  { label: 'Planes',      href: '#planes'      },
  { label: 'Extras',      href: '#extras'      },
  { label: 'Contacto',    href: '#contacto'    },
];
---

<footer id="footer" data-header={headerMode} class="bg-cream text-[#1a1a1a] font-[Raleway]">

  <!-- Divisor superior -->
  <div class="border-t border-[#1a1a1a]/10"></div>

  <!-- Contenido principal -->
  <div class="max-w-7xl mx-auto px-8 pt-16 pb-10 grid grid-cols-1 md:grid-cols-4 gap-y-10 gap-x-8">

    <!-- Col 1: Logo + redes -->
    <div class="ft-col flex flex-col gap-6">
      <img
        src="https://tupodcast.pe/wp-content/uploads/2023/11/logo_tupodcast.webp"
        alt="Logo"
        class="h-10 w-auto object-contain object-left"
        style="filter: brightness(0) saturate(100%)"
      />
      <div class="flex flex-col gap-2">
        <!-- Instagram -->
        <a href="https://instagram.com" target="_blank" rel="noopener"
           class="inline-flex items-center gap-2 text-sm font-light text-[#1a1a1a]/70 hover:text-gold transition-colors">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/>
            <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/>
          </svg>
          Instagram
        </a>
        <!-- TikTok -->
        <a href="https://tiktok.com" target="_blank" rel="noopener"
           class="inline-flex items-center gap-2 text-sm font-light text-[#1a1a1a]/70 hover:text-gold transition-colors">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
            <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.19 8.19 0 0 0 4.78 1.52V6.75a4.85 4.85 0 0 1-1.01-.06z"/>
          </svg>
          TikTok
        </a>
      </div>
    </div>

    <!-- Col 2: Vacío (espaciador) -->
    <div class="hidden md:block"></div>

    <!-- Col 3: Contacto -->
    <div class="ft-col flex flex-col items-start md:items-end gap-3">
      <a href="tel:+5191072031" class="text-base font-light text-[#1a1a1a]/70 hover:text-gold transition-colors">
        +51 991 072 031
      </a>
      <a href="mailto:hola@elpodcastdetuboda.com" class="text-base font-light text-[#1a1a1a]/70 hover:text-gold transition-colors">
        hola@elpodcastdetuboda.com
      </a>
    </div>

    <!-- Col 4: Nav -->
    <div class="ft-col flex flex-col gap-2 items-start md:items-end">
      {navItems.map(({ label, href }) => (
        <a href={href} class="text-base font-[500] text-[#1a1a1a]/70 hover:text-gold transition-colors">
          {label}
        </a>
      ))}
    </div>

  </div>

  <!-- Texto grande -->
  <div class="max-w-7xl mx-auto px-8 pb-10">
    <p class="ft-text text-[#1a1a1a] font-[200] text-[clamp(3rem,8vw,6rem)] font-moon leading-none">Cada historia</p>
    <p class="ft-text text-gold font-moon text-[clamp(3rem,8vw,6rem)] leading-none ">merece ser escuchada</p>
  </div>

  <!-- Barra inferior -->
  <div class="border-t border-[#1a1a1a]/10">
    <div class="max-w-7xl mx-auto px-8 py-5 flex flex-col md:flex-row items-center justify-between gap-3 text-[0.7rem] font-light text-[#1a1a1a]/50">
      <span>© Tu Podcast {new Date().getFullYear()}</span>
      <a href="#" class="hover:text-gold transition-colors">Política de Privacidad</a>
    </div>
  </div>

</footer>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const ftTl = gsap.timeline({
    scrollTrigger: { trigger: '#footer', start: 'top 80%' }
  });

  // Columnas: stagger desde abajo con fade
  ftTl.fromTo('.ft-col',
    { autoAlpha: 0, y: 40 },
    { autoAlpha: 1, y: 0, duration: 0.7, stagger: 0.15, ease: 'power3.out' }
  );

  // Texto grande: reveal con clip-path línea por línea
  ftTl.fromTo('.ft-text',
    { autoAlpha: 0, x: -60, clipPath: 'inset(0 100% 0 0)' },
    { autoAlpha: 1, x: 0, clipPath: 'inset(0 0% 0 0)', duration: 1, stagger: 0.2, ease: 'power4.out' },
    '-=0.3'
  );
</script>
